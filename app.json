{
  "expo": {
    "name": "UniClip",
    "slug": "uniclip",
    "scheme": "uniclipboard",
    "version": "1.3.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "buildNumber": "157",
      "supportsTablet": true,
      "appleTeamId": "8XG39X5CL8",
      "bundleIdentifier": "app.uniclipboard.UniClipboard",
      "infoPlist": { "ITSAppUsesNonExemptEncryption": false },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.app.uniclipboard.UniClipboard",
          "group.app.uniclipboard.ios"
        ]
      }
    },
    "android": {
      "versionCode": 157,
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/adaptive-icon-bg.png",
        "monochromeImage": "./assets/adaptive-icon-mono.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "app.uniclipboard.android",
      "permissions": ["android.permission.REQUEST_INSTALL_PACKAGES", "android.permission.CAMERA"]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      "./plugins/build/withNativeLogger.js",
      "./plugins/build/withNetworkSecurityConfig.js",
      "./plugins/build/withQuickSettingsTileManifest.js",
      "./plugins/build/withProcessTextManifest.js",
      "./plugins/build/withQuickActionActivity.js",
      "./plugins/build/withServiceRestartActivity.js",
      "./plugins/build/withAndroidNativeCode.js",
      "./plugins/build/withClipboardOverlayPermission.js",
      "./plugins/build/withNativeUtilPermission.js",
      "./plugins/build/withSmsPermission.js",
      "./plugins/build/withStaticSmsReceiver.js",
      "./plugins/build/withForegroundService.js",
      "./plugins/build/withAbiSplits.js",
      "./plugins/build/withGradleBuildTuning.js",
      "./plugins/build/withRustCore.js",
      "./plugins/build/withAndroidBuildVersionName.js",
      "@bacons/apple-targets",
      ["expo-sharing", { "android": { "enabled": true, "singleShareMimeTypes": ["*/*"] } }],
      ["expo-camera", { "cameraPermission": "授权 UniClip 使用相机以扫描二维码接入服务器" }],
      "expo-sqlite",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": ["zh-Hans", "en"],
            "android": ["zh", "en"]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "share",
                  "bundleIdentifier": "app.uniclipboard.UniClipboard.Share",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.app.uniclipboard.UniClipboard",
                      "group.app.uniclipboard.ios"
                    ]
                  }
                },
                {
                  "targetName": "keyboard",
                  "bundleIdentifier": "app.uniclipboard.UniClipboard.Keyboard",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.app.uniclipboard.UniClipboard",
                      "group.app.uniclipboard.ios"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
