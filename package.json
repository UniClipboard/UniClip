{
  "name": "uniclip",
  "version": "1.0.0",
  "main": "index.ts",
  "workspaces": [
    "modules/*"
  ],
  "scripts": {
    "start": "expo start",
    "start:clear": "mkdir -p logs && expo start --clear 2>&1 | tee -a logs/expo-start.log",
    "prebuild": "expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format-docs": "prettier --write \"**/*.{json,md}\"",
    "format-docs:check": "prettier --check \"**/*.{json,md}\"",
    "type-check": "tsc --noEmit",
    "build:apk": "cd android && gradlew assembleRelease",
    "plugin:build": "cd plugins && tsc -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "@expo/metro-runtime": "~56.0.15",
    "@expo/ui": "~56.0.18",
    "@expo/vector-icons": "^15.1.1",
    "@microsoft/signalr": "^10.0.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/stack": "^7.7.1",
    "@shopify/flash-list": "2.0.2",
    "app-group-store": "^1.0.0",
    "axios": "^1.13.5",
    "expo": "^56.0.12",
    "expo-application": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-crypto": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.18",
    "expo-intent-launcher": "~56.0.4",
    "expo-media-library": "~56.0.7",
    "expo-module-scripts": "~56.0.3",
    "expo-sharing": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "js-sha256": "^0.11.1",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-feather": "^1.1.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-logs": "^5.6.0",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-tab-view": "^4.3.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "segmentit": "^2.0.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3"
  },
  "private": true
}
